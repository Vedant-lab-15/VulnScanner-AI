# VulnScanner AI — Environment Configuration
# Copy to .env and fill in values. Never commit .env to version control.

# Logging level: DEBUG, INFO, WARNING, ERROR
VULNSCANNER_LOG_LEVEL=INFO

# OSV API (optional — set to false to disable external API calls)
VULNSCANNER_USE_OSV_API=true

# ML model path override (optional)
# VULNSCANNER_MODEL_PATH=/path/to/custom/model.joblib

# Max pages to crawl in URL scan mode
VULNSCANNER_MAX_PAGES=20

# Request timeout in seconds for URL scanning
VULNSCANNER_REQUEST_TIMEOUT=8
